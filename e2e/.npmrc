# Mirrors web/.npmrc — see docs/frontend-stack.md §4.4.
# NOTE: frozen-lockfile=true requires an existing pnpm-lock.yaml. For the very
# first install (no lockfile yet) bootstrap once with:
#     corepack pnpm install --no-frozen-lockfile
# After that the committed lockfile is the source of truth and installs are frozen.
frozen-lockfile=true
prefer-frozen-lockfile=true
auto-install-peers=false
strict-peer-dependencies=true
ignore-scripts=true
registry=https://registry.npmjs.org/
