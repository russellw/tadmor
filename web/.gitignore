# Frontend (Vite + React + TS, pnpm). Mirrors the supply-chain posture in
# docs/frontend-stack-design-notes.md: commit the lockfile (pin + integrity,
# like go.sum), never commit the installed tree (platform-specific build
# artifact, like Go's vendored source is NOT the analog here — the lockfile is).

# Installed dependency tree — never committed.
node_modules/

# pnpm content-addressable store, if created locally inside web/.
.pnpm-store/

# IMPORTANT: pnpm-lock.yaml is committed deliberately (Tier 1 vendoring).
# Do NOT add it here.

# Build output. dist/ is ignored except for the committed .gitkeep placeholder,
# which keeps the Go embed (web/embed.go: //go:embed all:dist) compiling before
# any `make web-build` has run.
dist/*
!dist/.gitkeep
dist-ssr/

# Vite / tooling caches.
.vite/
*.tsbuildinfo

# Test coverage.
coverage/

# Local-only overrides.
*.local
